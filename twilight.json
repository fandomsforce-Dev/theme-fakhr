{
  "name": {
    "ar": "ثيم فخر",
    "en": "Theme Raed"
  },
  "description": {
    "ar": "ثيم فخر المميز لمنصة سلة",
    "en": "Theme Fakhr for Salla platform"
  },
  "version": "1.0.0",
  "developer": "Fandom Force Dev",
  "repository": "https://github.com/fandomsforce-Dev/theme-fakhr",
  "features": [
    "mega-menu",
    "fonts",
    "colors",
    "breadcrumb",
    "equal_card_height",
    "product-filters"
  ],
  "settings": {
    "sections": [
      {
        "id": "general_options_section",
        "title": {
          "ar": "خيارات عامة للمتجر",
          "en": "General Store Options"
        },
        "icon": "salla-icon:cog",
        "fields": [
          {
            "id": "logo_position",
            "type": "select",
            "label": {
              "ar": "مكان الشعار",
              "en": "Logo Position"
            },
            "value": "right",
            "options": [
              {
                "value": "right",
                "label": {
                  "ar": "اليمين",
                  "en": "Right"
                }
              },
              {
                "value": "center",
                "label": {
                  "ar": "المنتصف",
                  "en": "Center"
                }
              }
            ]
          },
          {
            "id": "logo_width",
            "type": "number",
            "label": {
              "ar": "عرض الشعار (px)",
              "en": "Logo Width (px)"
            },
            "value": 150,
            "min": 50,
            "max": 300
          },
          {
            "id": "menu_position",
            "type": "radio-list",
            "label": {
              "ar": "مكان المنيو",
              "en": "Menu Position"
            },
            "value": "right",
            "options": [
              {
                "value": "right",
                "label": {
                  "ar": "يمين",
                  "en": "Right"
                }
              },
              {
                "value": "center",
                "label": {
                  "ar": "منتصف",
                  "en": "Center"
                }
              }
            ]
          },
          {
            "id": "header_is_sticky",
            "type": "switch",
            "label": {
              "ar": "الهيدر المثبت",
              "en": "Sticky Header"
            },
            "value": true
          },
          {
            "id": "topnav_is_dark",
            "type": "switch",
            "label": {
              "ar": "تحويل الشريط العلوي للوضع الداكن",
              "en": "Dark Top Navigation Bar"
            },
            "value": false
          },
          {
            "id": "important_links",
            "type": "switch",
            "label": {
              "ar": "عرض الروابط الهامة في الشريط العلوي",
              "en": "Show Important Links in Top Navigation Bar"
            },
            "value": true
          }
        ]
      },
      {
        "id": "product_page_section",
        "title": {
          "ar": "خيارات صفحة المنتج",
          "en": "Product Page Options"
        },
        "icon": "salla-icon:box",
        "fields": [
          {
            "id": "slider_background_size",
            "type": "select",
            "label": {
              "ar": "طريقة عرض صور المنتج في السليدر",
              "en": "Product Slider Image Size"
            },
            "value": "contain",
            "options": [
              {
                "value": "cover",
                "label": {
                  "ar": "تغطية كاملة (Cover)",
                  "en": "Cover"
                }
              },
              {
                "value": "contain",
                "label": {
                  "ar": "احتواء كامل (Contain)",
                  "en": "Contain"
                }
              }
            ]
          },
          {
            "id": "imageZoom",
            "type": "switch",
            "label": {
              "ar": "تفعيل تكبير الصور (Zoom)",
              "en": "Enable Image Zoom"
            },
            "value": true
          }
        ]
      }
    ]
  },
  "components": [
    {
      "id": "home.enhanced-slider",
      "name": {
        "ar": "صور متحركة محسنة",
        "en": "Enhanced Slider"
      },
      "icon": "salla-icon:image",
      "fields": [
        {
          "id": "static-label2",
          "type": "static",
          "value": "<h6>إعدادات الشرائح (البنرات)</h6>"
        },
        {
          "id": "slides",
          "type": "collection",
          "label": {
            "ar": "الشرائح",
            "en": "Slides"
          },
          "minLength": 1,
          "maxLength": 10,
          "fields": [
            {
              "id": "image",
              "type": "image",
              "label": {
                "ar": "صورة البنر",
                "en": "Banner Image"
              },
              "dimensions": "900x600"
            },
            {
              "id": "title",
              "type": "text",
              "label": {
                "ar": "العنوان الرئيسي",
                "en": "Main Title"
              }
            },
            {
              "id": "subtitle",
              "type": "text",
              "label": {
                "ar": "النص الإضافي",
                "en": "Subtitle"
              }
            },
            {
              "id": "without_overlay",
              "type": "switch",
              "label": {
                "ar": "إزالة طبقة التعتيم من فوق الصورة",
                "en": "Remove Overlay From Image"
              },
              "value": false
            }
          ]
        }
      ]
    },
    {
      "id": "home.main-links",
      "name": {
        "ar": "الروابط السريعة",
        "en": "Quick Links"
      },
      "icon": "salla-icon:link",
      "fields": [
        {
          "id": "merge_with_top_component",
          "type": "switch",
          "label": {
            "ar": "دمج المكون مع العنصر السابق (يفضل استخدامه إذا كان السابق هو السليدر المحسن)",
            "en": "Merge component with the previous element"
          },
          "value": false
        },
        {
          "id": "show_cats",
          "type": "switch",
          "label": {
            "ar": "تحويل المكون لعرض روابط التصنيفات مباشرة",
            "en": "Convert component to display category links directly"
          },
          "value": false
        }
      ]
    },
    {
      "id": "home.slider-products-with-header",
      "name": {
        "ar": "منتجات متحركة مع خلفية مخصصة للقسم",
        "en": "Slider Products with Header Background"
      },
      "icon": "salla-icon:box",
      "fields": [
        {
          "id": "static-label4",
          "type": "static",
          "value": "<h6>إعدادات القسم</h6>"
        },
        {
          "id": "background_image",
          "type": "image",
          "label": {
            "ar": "صورة الخلفية للقسم",
            "en": "Section Background Image"
          },
          "dimensions": "1233x500"
        },
        {
          "id": "products",
          "type": "products",
          "label": {
            "ar": "المنتجات",
            "en": "Products"
          },
          "maxLength": 8
        }
      ]
    }
  ]
}
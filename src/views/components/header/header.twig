{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int      |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}

{% set important_links = theme.settings.get('important_links') %}
{% set logo_position = theme.settings.get('logo_position', 'center') %}
{% set menu_position = theme.settings.get('menu_position', 'right') %}

{# حاوية ذكية تحمل إعدادات لوحة التحكم كـ Classes ديناميكية للاعتماد عليها بالكامل في الـ CSS #}
<div class="theme-header-setting logo-{{ logo_position }} menu-{{ menu_position }}">

<header class="store-header">
  {# Top Nav #}
  <div class="top-navbar">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
          </div>

          {% if store.scope %}
              <button class="btn--rounded-gray"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          <div class="header-search flex-1">
            <salla-search inline oval height="36"></salla-search>
          </div>
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  {# Main Nav #}
  <div id="mainnav" class="main-nav-container shadow-default bg-white flex items-center py-4">
      <div class="inner bg-inherit w-full">
          <div class="container">
              
              {# حاوية الهيدر الرئيسية المرنة #}
              <div class="flex w-full items-center justify-between relative" id="header-inner-flex">

                  {# 1. قسم اللوجو #}
                  <div class="logo-block flex items-center flex-none" id="logo-wrapper">
                      <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                        <i class="sicon-menu text-primary text-2xl"></i>
                      </a>

                      <a class="navbar-brand m-0" href="{{ store.url }}" style="max-width: var(--logo-width, auto) !important; display: block; width: 100%;">
                          <img fetchpriority="high" 
                               width="100%" 
                               height="100%" 
                               loading="eager" 
                               src="{{ store.logo|cdn(300) }}" 
                               alt="{{ store.name }} logo">
                          
                          {% if is_page('index') %}
                            <h1 class="sr-only">{{ store.name }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name }}</h2>
                          {% endif %}
                      </a>
                  </div>

                  {# 2. قسم المنيو الرئيسي #}
                  <div class="menu-block flex" id="menu-wrapper">
                      <custom-main-menu></custom-main-menu>
                  </div>

                  {# 3. قسم السلة والحساب وتجربة الاتصال #}
                  <div class="actions-block flex items-center justify-end flex-none gap-2" id="actions-wrapper">
                      <div class="welcome-message text-green-600 font-bold mx-2 px-3 py-1 bg-green-50 rounded-full">
                         تجربة الاتصال
                      </div>
                      <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
                      <salla-cart-summary class="ml-4 rtl:ml-[unset] rtl:mr-4">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                      </salla-cart-summary>
                  </div>

              </div>

          </div>
      </div>
  </div>
</header>

</div>

{# 🎯 الستايل الهندسي المعزز لحل مشكلة التموضع المطلق والـ Sticky بشكل نهائي وقاطع #}
<style>
  body .navbar-brand {
      float: none !important;
      margin: 0 !important;
      max-width: var(--logo-width, auto) !important;
      width: var(--logo-width, 100%) !important;
  }

  body .navbar-brand img {
      width: 100% !important;
      height: auto !important;
      max-width: 100% !important;
      object-fit: contain !important;
  }

  /* منع أي flex نمو في المنيو بشكل عام */
  body #menu-wrapper,
  body .is-sticky #menu-wrapper,
  body .fixed-header #menu-wrapper {
      flex: 0 0 auto !important;
  }

  @media (min-width: 1024px) {
      /* التثبيت الأساسي لمرونة الحاوية */
      body #header-inner-flex,
      body .fixed-header #header-inner-flex,
      body .is-sticky #header-inner-flex,
      body [id^="mainnav"] #header-inner-flex {
          display: flex !important;
          width: 100% !important;
          align-items: center !important;
          justify-content: space-between !important;
          position: relative !important;
      }

      /* تنسيق المنيو الأساسي - يمنع الانضغاط تمامًا */
      body #menu-wrapper,
      body #menu-wrapper custom-main-menu,
      body #menu-wrapper ul,
      body .is-sticky #menu-wrapper,
      body .fixed-header #menu-wrapper,
      body .is-sticky #menu-wrapper custom-main-menu,
      body .fixed-header #menu-wrapper custom-main-menu {
          display: flex !important;
          flex-direction: row !important;
          align-items: center !important;
          gap: 28px !important;
          white-space: nowrap !important;
          flex-wrap: nowrap !important;
          overflow: visible !important;
      }

      /* منع أي عناصر داخلية من الانضغاط */
      body #menu-wrapper li,
      body #menu-wrapper a,
      body .is-sticky #menu-wrapper li,
      body .fixed-header #menu-wrapper li {
          flex-shrink: 0 !important;
          white-space: nowrap !important;
      }

      body #logo-wrapper, 
      body #actions-wrapper {
          z-index: 30 !important;
      }

      /* ──────────────────────────────────────────────────────────
         الحالة 1: اللوجو يمين والمنيو في المنتصف (الحل النهائي)
         ────────────────────────────────────────────────────────── */
      .theme-header-setting.logo-right.menu-center #menu-wrapper,
      body .is-sticky .theme-header-setting.logo-right.menu-center #menu-wrapper,
      body .fixed-header .theme-header-setting.logo-right.menu-center #menu-wrapper {
          position: absolute !important;
          left: 50% !important;
          top: 50% !important;
          transform: translate(-50%, -50%) !important;
          margin: 0 !important;
          padding: 0 !important;
          width: auto !important;
          max-width: none !important;
          flex: 0 0 auto !important;
          justify-content: center !important;
          z-index: 10 !important;
      }
      
      /* ضمان أن المحتوى الداخلي للمنيو لا ينضغط أبدًا */
      .theme-header-setting.logo-right.menu-center #menu-wrapper custom-main-menu,
      .theme-header-setting.logo-right.menu-center #menu-wrapper ul,
      body .is-sticky .theme-header-setting.logo-right.menu-center #menu-wrapper custom-main-menu,
      body .is-sticky .theme-header-setting.logo-right.menu-center #menu-wrapper ul,
      body .fixed-header .theme-header-setting.logo-right.menu-center #menu-wrapper custom-main-menu,
      body .fixed-header .theme-header-setting.logo-right.menu-center #menu-wrapper ul {
          justify-content: center !important;
          width: auto !important;
          flex-direction: row !important;
          flex-wrap: nowrap !important;
          gap: 28px !important;
      }

      /* ──────────────────────────────────────────────────────────
         الحالة 2: اللوجو يمين والمنيو يمين
         ────────────────────────────────────────────────────────── */
      .theme-header-setting.logo-right.menu-right #menu-wrapper {
          position: static !important;
          transform: none !important;
          flex: 1 !important;
          justify-content: flex-start !important;
          padding-right: 35px !important;
          padding-left: 0 !important;
          margin: 0 !important;
          width: auto !important;
      }
      .theme-header-setting.logo-right.menu-right #menu-wrapper custom-main-menu,
      .theme-header-setting.logo-right.menu-right #menu-wrapper ul {
          justify-content: flex-start !important;
          width: auto !important;
      }

      /* ──────────────────────────────────────────────────────────
         الحالة 3: اللوجو والمنيو كلاهما في المنتصف
         ────────────────────────────────────────────────────────── */
      .theme-header-setting.logo-center.menu-center #header-inner-flex {
          flex-direction: column !important;
          gap: 16px !important;
          align-items: center !important;
          justify-content: center !important;
      }
      .theme-header-setting.logo-center.menu-center #logo-wrapper,
      .theme-header-setting.logo-center.menu-center #menu-wrapper {
          position: static !important;
          transform: none !important;
          margin: 0 auto !important;
          width: auto !important;
          justify-content: center !important;
      }
      .theme-header-setting.logo-center.menu-center #actions-wrapper {
          position: absolute !important;
          left: 0 !important;
          top: 50% !important;
          transform: translateY(-50%) !important;
      }

      /* ──────────────────────────────────────────────────────────
         الحالة 4: اللوجو في المنتصف والمنيو يمين
         ────────────────────────────────────────────────────────── */
      .theme-header-setting.logo-center:not(.menu-center) #logo-wrapper {
          position: absolute !important;
          left: 50% !important;
          top: 50% !important;
          transform: translate(-50%, -50%) !important;
      }
      .theme-header-setting.logo-center:not(.menu-center) #menu-wrapper {
          position: static !important;
          transform: none !important;
          flex: 1 !important;
          justify-content: flex-start !important;
          padding-right: 0 !important;
      }
  }
</style>
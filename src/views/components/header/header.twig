{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int      |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}

{% set important_links = theme.settings.get('important_links') %}
{% set logo_position = theme.settings.get('logo_position', 'center') %}
{% set menu_position = theme.settings.get('menu_position', 'right') %}

<header class="store-header">
  {# Top Nav #}
  <div class="top-navbar">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
          </div>

          {% if store.scope %}
              <button class="btn--rounded-gray"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          <div class="header-search flex-1">
            <salla-search inline oval height="36"></salla-search>
          </div>
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  {# Main Nav #}
  <div id="mainnav" class="main-nav-container shadow-default bg-white flex items-center py-4">
      <div class="inner bg-inherit w-full">
          <div class="container">
              
              {# حاوية مرنة تجمع العناصر بتوزيع طبيعي #}
              <div class="flex w-full items-center justify-between relative" id="header-inner-flex">

                  {# حاوية تجمع اللوجو والمنيو في الجهة اليمنى دائماً #}
                  <div class="flex items-center gap-6 flex-1 justify-start" id="right-side-zone">
                      
                      {# 1. قسم اللوجو #}
                      <div class="logo-block flex items-center" id="logo-wrapper">
                          <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                            <i class="sicon-menu text-primary text-2xl"></i>
                          </a>

                          <a class="navbar-brand m-0" href="{{ store.url }}" style="max-width: var(--logo-width, auto) !important; display: block; width: 100%;">
                              <img fetchpriority="high" 
                                   width="100%" 
                                   height="100%" 
                                   loading="eager" 
                                   src="{{ store.logo|cdn(300) }}" 
                                   alt="{{ store.name }} logo">
                              
                              {% if is_page('index') %}
                                <h1 class="sr-only">{{ store.name }}</h1>
                              {% else %}
                                <h2 class="sr-only">{{ store.name }}</h2>
                              {% endif %}
                          </a>
                      </div>

                      {# 2. قسم المنيو الرئيسي #}
                      <div class="menu-block flex justify-start" id="menu-wrapper">
                          <custom-main-menu></custom-main-menu>
                      </div>

                  </div>

                  {# 3. قسم السلة والحساب وتجربة الاتصال #}
                  <div class="actions-block flex items-center justify-end" id="actions-wrapper">
                      <div class="welcome-message text-green-600 font-bold mx-2 px-3 py-1 bg-green-50 rounded-full">
                         تجربة الاتصال
                      </div>
                      <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
                      <salla-cart-summary class="ml-4 rtl:ml-[unset] rtl:mr-4">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                      </salla-cart-summary>
                  </div>

              </div>

          </div>
      </div>
  </div>
</header>

{# 🎯 التعديل هِنا يركز بالكامل على تقريب المنيو من اللوجو في وضع اليمين #}
<style>
  body .navbar-brand {
      float: none !important;
      margin: 0 !important;
      max-width: var(--logo-width, auto) !important;
      width: var(--logo-width, 100%) !important;
  }

  body .navbar-brand img {
      width: 100% !important;
      height: auto !important;
      max-width: 100% !important;
      object-fit: contain !important;
  }

  @media (min-width: 1024px) {
      /* ─── ضبط التوزيع الافتراضي المستقر للحاوية الكبيرة ─── */
      body #header-inner-flex {
          display: flex !important;
          width: 100% !important;
          align-items: center !important;
          justify-content: space-between !important;
      }

      /* ─── حالة: اللوجو يمين والمنيو بالمنتصف ─── */
      body.body-menu-center #right-side-zone {
          display: flex !important;
          flex: 1 !important;
          justify-content: space-between !important;
          align-items: center !important;
          gap: 0 !important;
      }

      body.body-menu-center #logo-wrapper {
          flex: 0 0 auto !important;
      }

      body.body-menu-center #menu-wrapper {
          position: static !important;
          transform: none !important;
          flex: 1 !important;
          display: flex !important;
          justify-content: center !important;
          margin: 0 !important;
      }
      
      body.body-menu-center #menu-wrapper custom-main-menu {
          display: flex !important;
          justify-content: center !important;
          width: auto !important;
      }

      body.body-menu-center #actions-wrapper {
          flex: 0 0 auto !important;
      }

      /* ─── حالة: اللوجو يمين والمنيو يمين (حل مشكلة الفراغ الكبير) ─── */
      body:not(.body-menu-center) #right-side-zone {
          display: flex !important;
          justify-content: flex-start !important; /* إلغاء التوزيع المتباعد وتثبيت البداية من اليمين */
          flex: 1 !important;
          gap: 30px !important; /* المسافة المباشرة الحقيقية بين اللوجو وبداية المنيو */
      }

      body:not(.body-menu-center) #menu-wrapper {
          position: static !important;
          transform: none !important;
          margin: 0 !important;
          padding: 0 !important;
          justify-content: flex-start !important;
          flex: 0 0 auto !important; /* منع الحاوية من التمدد وأخذ مساحة أكبر من اللوجو */
          width: auto !important;
      }

      /* استهداف وسم المنيو الفعلي وعناصره الداخلية لكسر أي مسافات تلقائية */
      body:not(.body-menu-center) custom-main-menu,
      body:not(.body-menu-center) #menu-wrapper custom-main-menu,
      body:not(.body-menu-center) custom-main-menu .main-menu,
      body:not(.body-menu-center) custom-main-menu ul {
          display: flex !important;
          justify-content: flex-start !important;
          width: auto !important; /* إجبار المنيو على أخذ حجم النصوص فقط */
          max-width: max-content !important;
          margin: 0 !important;
          padding: 0 !important;
          gap: 20px !important; /* المسافة بين روابط المنيو نفسها (فساتين، تنانير...) */
      }

      /* ─── حالة سنترة اللوجو فقط ─── */
      body.body-logo-center #logo-wrapper {
          position: absolute !important;
          left: 50% !important;
          top: 50% !important;
          transform: translate(-50%, -50%) !important;
          z-index: 10 !important;
       }
       body.body-logo-center #menu-wrapper {
          margin-right: 0 !important;
          justify-content: flex-start !important;
       }

      /* ─── الحالة القصوى: اللوجو والمنيو كلاهما في المنتصف ─── */
      body.body-logo-center.body-menu-center #header-inner-flex {
          flex-direction: column !important;
          gap: 12px !important;
      }
      body.body-logo-center.body-menu-center #logo-wrapper,
      body.body-logo-center.body-menu-center #menu-wrapper {
          position: static !important;
          transform: none !important;
          margin: 0 auto !important;
          justify-content: center !important;
      }
      body.body-logo-center.body-menu-center #right-side-zone {
          flex-direction: column !important;
          width: 100% !important;
          gap: 8px !important;
      }
      body.body-logo-center.body-menu-center #actions-wrapper {
          position: absolute !important;
          left: 0 !important;
          top: 50% !important;
          transform: translateY(-50%) !important;
      }
  }
</style>
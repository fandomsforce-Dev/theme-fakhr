{% set important_links = theme.settings.get('important_links') %}
{% set logo_position = theme.settings.get('logo_position', 'center') %}
{% set menu_position = theme.settings.get('menu_position', 'right') %}
{% set header_height = theme.settings.get('header_height', 84) %}

<div class="theme-header-setting logo-{{ logo_position }} menu-{{ menu_position }}" 
     style="--header-min-height: {{ header_height }}px; --header-py: 16px;">

<<header class="store-header">
  {# Top Nav #}
  <div class="top-navbar">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
          </div>

          {% if store.scope %}
              <button class="btn--rounded-gray"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          <div class="header-search flex-1">
            <salla-search inline oval height="36"></salla-search>
          </div>
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  {# Main Nav #}
  <div id="mainnav" class="main-nav-container shadow-default bg-white flex items-center">
      <div class="inner bg-inherit w-full">
          <div class="container">
              <div class="flex w-full items-center justify-between relative" id="header-inner-flex">

                  {# 1. اللوجو #}
                  <div class="logo-block flex items-center flex-none" id="logo-wrapper">
                      <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                        <i class="sicon-menu text-primary text-2xl"></i>
                      </a>

                      <a class="navbar-brand m-0" href="{{ store.url }}" 
                         style="max-width: var(--logo-width, auto); display: block; width: 100%;">
                          <img fetchpriority="high" 
                               width="100%" 
                               height="100%" 
                               loading="eager" 
                               src="{{ store.logo|cdn(300) }}" 
                               alt="{{ store.name }} logo">
                          
                          {% if is_page('index') %}
                            <h1 class="sr-only">{{ store.name }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name }}</h2>
                          {% endif %}
                      </a>
                  </div>

                  {# 2. المنيو #}
                  <div class="menu-block flex" id="menu-wrapper">
                      <custom-main-menu></custom-main-menu>
                  </div>

                  {# 3. الأزرار #}
                  <div class="actions-block flex items-center justify-end flex-none gap-2" id="actions-wrapper">
                      <div class="welcome-message text-green-600 font-bold mx-2 px-3 py-1 bg-green-50 rounded-full">
                        تست
                      </div>
                      <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
                      <salla-cart-summary class="ml-4 rtl:ml-[unset] rtl:mr-4">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                      </salla-cart-summary>
                  </div>

              </div>
          </div>
      </div>
  </div>
</header>

</div>

{# ===== 🎨 CSS عام (بدون أي شروط Twig داخله) ===== #}
<style>
  body .navbar-brand {
    float: none;
    margin: 0;
    max-width: var(--logo-width, auto);
    width: var(--logo-width, 100%);
  }

  body .navbar-brand img {
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .main-nav-container {
    min-height: var(--header-min-height, 84px);
    padding-top: var(--header-py, 16px);
    padding-bottom: var(--header-py, 16px);
    display: flex;
    align-items: center;
  }

  @media (min-width: 1024px) {
    #header-inner-flex {
      display: flex;
      width: 100%;
      align-items: center;
      justify-content: space-between;
      position: relative;
    }

    #menu-wrapper,
    #menu-wrapper custom-main-menu,
    #menu-wrapper ul {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 16px;
      white-space: nowrap;
    }

    #logo-wrapper, 
    #actions-wrapper {
      z-index: 30;
    }

    /* وضعية: لوجو يمين + منيو يمين */
    .theme-header-setting.logo-right.menu-right #menu-wrapper {
      position: static;
      transform: none;
      flex: 1;
      justify-content: flex-start;
      padding-right: 35px;
      padding-left: 0;
      margin: 0;
      width: auto;
    }

    /* وضعية: لوجو سنتر + منيو سنتر */
    .theme-header-setting.logo-center.menu-center #header-inner-flex {
      flex-direction: column;
      gap: 16px;
      align-items: center;
      justify-content: center;
    }
    .theme-header-setting.logo-center.menu-center #logo-wrapper,
    .theme-header-setting.logo-center.menu-center #menu-wrapper {
      position: static;
      transform: none;
      margin: 0 auto;
      width: auto;
      justify-content: center;
    }
    .theme-header-setting.logo-center.menu-center #actions-wrapper {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    /* وضعية: لوجو سنتر + منيو يمين */
    .theme-header-setting.logo-center:not(.menu-center) #logo-wrapper {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }
    .theme-header-setting.logo-center:not(.menu-center) #menu-wrapper {
      position: static;
      transform: none;
      flex: 1;
      justify-content: flex-start;
      padding-right: 0;
    }
  }
</style>

{# ===== 🎨 CSS خاص بوضعية لوجو يمين + منيو سنتر (منفصل تماماً) ===== #}
{% if logo_position == 'right' and menu_position == 'center' %}
<style>
  @media (min-width: 1024px) {
    .theme-header-setting.logo-right.menu-center .main-nav-container,
    .theme-header-setting.logo-right.menu-center #mainnav,
    .theme-header-setting.logo-right.menu-center .is-sticky #mainnav,
    .theme-header-setting.logo-right.menu-center .fixed-header #mainnav,
    .theme-header-setting.logo-right.menu-center .is-sticky .main-nav-container,
    .theme-header-setting.logo-right.menu-center .fixed-header .main-nav-container,
    .theme-header-setting.logo-right.menu-center #mainnav .inner {
      padding-top: var(--header-py, 16px) !important;
      padding-bottom: var(--header-py, 16px) !important;
      min-height: var(--header-min-height, 84px) !important;
      display: flex !important;
      align-items: center !important;
    }

    .theme-header-setting.logo-right.menu-center #menu-wrapper {
      position: absolute !important;
      left: 50% !important;
      top: 50% !important;
      transform: translate(-50%, -50%) !important;
      margin: 0 !important;
      padding: 0 !important;
      width: max-content !important; 
      max-width: 60% !important; 
      display: flex !important;
      justify-content: center !important;
      z-index: 10 !important;
    }
  }
</style>
{% endif %}
{#
| Variable           | Type      | Description                                                   |
|---------------------|-----------|----------------------------------------------------------------|
| instance.fields     | object    | الحقول المباشرة المعرفة داخل ملف الـ JSON                     |
#}

{# 🎯 الحل الحاسم للعنوان: فحص إذا كان الحقل مصفوفة لغات (كائن) أو نصاً مباشراً #}
{% set raw_title = instance.fields.custom_section_title.value %}
{% if raw_title is iterable %}
    {# جلب لغة المتجر الحالية المفتوحة (عربي أو إنجليزي) #}
    {% set block_title = raw_title[app.current_language]|default(raw_title.ar)|default(raw_title.en)|default('منتجات متحركة مخصصة') %}
{% else %}
    {% set block_title = raw_title|default('منتجات متحركة مخصصة') %}
{% endif %}

{# 2. تنقية واستخراج قيمة نوع المنتجات #}
{% set raw_source = instance.fields.mntgat_mthrkt_mkhsst.value %}
{% set slider_source = raw_source.value|default(raw_source is iterable ? raw_source[0].value|default(raw_source[0]) : raw_source)|default('latest') %}

{# 3. تنقية واستخراج قيمة عدد المنتجات #}
{% set raw_limit = instance.fields.products_limit.value %}
{% set limit_value = raw_limit.value|default(raw_limit is iterable ? raw_limit[0].value|default(raw_limit[0]) : raw_limit)|default('4') %}

<section class="s-block s-block--best-offers container overflow-hidden mt-6 sm:mt-8">

    <salla-products-slider
        source="{{ slider_source }}"
        limit="{{ limit_value }}"
        autoplay
        block-title="{{ block_title }}"
        block-subTitle=""
        slider-id="slider-final-v2-{{ instance.id|default('custom') }}">
    </salla-products-slider>

</section>
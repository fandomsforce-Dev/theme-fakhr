{#
| Variable           | Type      | Description                                                   |
|---------------------|-----------|----------------------------------------------------------------|
| instance.fields     | object    | يحتوي على الحقول المباشرة المعرفة للمكون                     |
| instance.settings   | object    | يحتوي على الإعدادات العامة                                    |
#}

{# 🎯 الطريقة القياسية المباشرة لطباعة الحقل النصي حسب الدوكيومنتيش #}
{% set block_title = instance.fields.custom_section_title.value|default(instance.fields.custom_section_title)|default(instance.settings.custom_section_title)|default('منتجات متحركة مخصصة') %}

{# جلب المصدر والعدد المستقرين عندك #}
{% set slider_source = instance.fields.mntgat_mthrkt_mkhsst.value|default('latest') %}
{% set limit_value = instance.fields.products_limit.value|default(4) %}

<section class="s-block s-block--best-offers container overflow-hidden mt-6 sm:mt-8">

    <salla-products-slider
        source="{{ slider_source }}"
        limit="{{ limit_value }}"
        autoplay
        block-title="{{ block_title }}"
        block-subTitle=""
        slider-id="slider-final-pure-{{ instance.id|default('custom') }}">
    </salla-products-slider>

</section>
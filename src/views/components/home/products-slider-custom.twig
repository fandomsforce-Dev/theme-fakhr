{#
| Variable            | Type      | Description                                                    |
|---------------------|-----------|----------------------------------------------------------------|
| instance.settings   | object    | يحتوي على الإعدادات التي يتم اختيارها من لوحة التحكم          |
#}

{# 🎯 التقاط القيمة وفحص ما إذا كانت نصاً أو كائناً يحتوي على value #}
{% set raw_value = instance.settings.mntgat_mthrkt_mkhsst %}
{% set display_type = raw_value.value|default(raw_value)|default('latest') %}

<section class="s-block container mt-6 sm:mt-8">
    
    <div class="s-block__title mb-6">
        <h2>{{ instance.settings.title|default('منتجات متحركة مخصصة') }}</h2>
    </div>

    {# 🎯 فحص الخيار بعد التنقية #}
    {% if display_type == 'category' %}
        
        {% if instance.settings.selected_category %}
            <salla-products-list 
                source="category" 
                source-value="{{ instance.settings.selected_category }}">
            </salla-products-list>
        {% else %}
            <div class="text-center py-8 text-gray-400 border border-dashed border-gray-200 rounded-lg">
                يرجى اختيار التصنيف من لوحة التحكم ليتم عرض منتجاته.
            </div>
        {% endif %}

    {% elseif display_type == 'best-seller' %}
        
        {# استدعاء رسمي للأكثر مبيعاً #}
        <salla-products-list source="best_seller"></salla-products-list>

    {% else %}
        
        {# استدعاء افتراضي لأحدث المنتجات #}
        <salla-products-list source="latest"></salla-products-list>

    {% endif %}

</section>
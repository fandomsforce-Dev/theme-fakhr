{#
| Variable            | Type      | Description                                                    |
|---------------------|-----------|----------------------------------------------------------------|
| instance.settings   | object    | يحتوي على الإعدادات التي يتم اختيارها من لوحة التحكم          |
#}

{# 🎯 1. تنقية القيمة الملتقطة من حقل نوع المنتجات #}
{% set raw_value = instance.settings.mntgat_mthrkt_mkhsst %}
{% set display_type = raw_value.value|default(raw_value)|default('latest') %}

{# 🎯 2. تحديد مصدر المنتجات بناءً على خيار التاجر #}
{# إذا اختار التاجر تصنيف، نمرر المعرف للحقل الثاني، وإلا نمرر display_type مباشرة (latest أو best_seller) #}
{% set slider_source = (display_type == 'category') ? 'category' : display_type %}
{% set source_value = (display_type == 'category') ? instance.settings.selected_category : '' %}

<section id="custom-products-slider-block" class="s-block s-block--best-offers container overflow-hidden mt-6 sm:mt-8">
    
    {# استدعاء الـ Slider الرسمي من سلة وتمرير الإعدادات ديناميكياً #}
    <salla-products-slider
        source="{{ slider_source }}"
        source-value="{{ source_value }}"
        limit="10"
        autoplay
        block-title="{{ instance.settings.title|default('منتجات متحركة مخصصة') }}"
        block-subTitle=""
        slider-id="slider-custom-{{ instance.id|default('1') }}">
    </salla-products-slider>

</section>